# Copy to .env.local (gitignored) for local dev/ngrok to write to the same
# shared Supabase table as the deployed GitHub Pages prototype.
# Get these from the Supabase project → Settings → API.
# NEXT_PUBLIC_SUPABASE_ANON_KEY must be the "publishable" key (sb_publishable_...).
# Never put the "secret" key (sb_secret_...) in a NEXT_PUBLIC_* variable — it
# gets embedded in the public JS bundle shipped to GitHub Pages.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
